# ==========================================
# JARVIS VPS - ENVIRONMENT CONFIGURATION
# ==========================================

# ── REQUIRED (App will not start without these) ──
# LLM_PROVIDER can be: claude, openai, gemini, groq
LLM_PROVIDER=claude
LLM_MODEL=

# You only need the API key for your chosen LLM_PROVIDER
# You can provide multiple keys separated by commas. If a key runs out of credits,
# Jarvis will auto-switch to the next one and log the dead key.
ANTHROPIC_API_KEY=your_anthropic_api_key_here,second_key_here
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Generate a secure JWT secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_32_byte_hex_secret_here
JARVIS_USERNAME=admin
# For dev: plain text password. For prod: use passlib bcrypt hash
JARVIS_PASSWORD=your_secure_password_here

# ── OPTIONAL (Features gracefully disable if missing) ──
# Google Search and Dork support via SerpAPI
SERPAPI_KEY=

# High quality TTS (online)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Redis session and search caching (Fast)
REDIS_URL=redis://redis:6379/0

# ── GENERAL CONFIG ──
WHISPER_MODEL=medium
TTS_ENGINE=pyttsx3
VPS_DOMAIN=yourdomain.com
PORT=8000
ALLOWED_ORIGINS=http://localhost,https://yourdomain.com

# ── PATHS (Defaults are fine for Docker) ──
DOWNLOAD_FOLDER=./downloads
AUDIO_CACHE_FOLDER=./audio_cache
LOG_FILE=./logs/jarvis.log
DORK_AUDIT_LOG=./logs/dork_audit.log

# ── TUNING & LIMITS ──
MAX_AUDIO_SIZE_MB=25
MAX_INPUT_LENGTH=2000
SESSION_HISTORY_LENGTH=20
RATE_LIMIT=60/minute
SEARCH_CACHE_TTL=600
WEATHER_CACHE_TTL=1800
AUDIO_CACHE_TTL=300

# ── DEBUG ──
HEADLESS_MODE=true
DEBUG=false
